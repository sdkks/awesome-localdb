{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sdkks/awesome-localdb/main/schemas/index.schema.json",
  "title": "Awesome Local DB — Aggregated Index",
  "description": "Generated by scripts/build-index.sh from databases/*/metadata.json. Never edit manually.",
  "type": "object",
  "required": ["generated_at", "schema_version", "count", "databases"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of generation."
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of database entries."
    },
    "databases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name", "slug", "category", "categories", "description",
          "homepage_url", "repository_url", "license", "languages",
          "format_on_disk", "core_strengths", "best_use_cases",
          "tags", "custom_tags", "github_stars", "maintenance_status",
          "first_release_year", "requires_server", "remarks",
          "_search_tokens", "_repo_path", "_has_examples"
        ],
        "properties": {
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "category": { "type": "string" },
          "categories": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "homepage_url": { "type": "string", "format": "uri" },
          "repository_url": { "type": "string", "format": "uri" },
          "license": { "type": "string" },
          "languages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "ecosystem"],
              "properties": {
                "name": { "type": "string" },
                "ecosystem": { "type": "string" }
              }
            }
          },
          "format_on_disk": { "type": "string" },
          "core_strengths": { "type": "array", "items": { "type": "string" } },
          "best_use_cases": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "custom_tags": { "type": "array", "items": { "type": "string" } },
          "github_stars": { "type": "integer" },
          "maintenance_status": { "type": "string" },
          "first_release_year": { "type": "integer" },
          "requires_server": { "type": "boolean" },
          "remarks": { "type": "string" },
          "comparisons": { "type": "array", "items": { "type": "string", "format": "uri" } },
          "_search_tokens": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Pre-computed lowercased search tokens for client-side text search."
          },
          "_repo_path": {
            "type": "string",
            "description": "Relative path to the database directory within the repository."
          },
          "_has_examples": {
            "type": "boolean",
            "description": "True if at least one language subdirectory exists with recipe files."
          }
        }
      }
    }
  }
}
